prefix_rule(pattern=["git", "add", "README.md", "docs/architecture.md", "infra/docker-compose.yml", "pyproject.toml", "src/rag_memories/embeddings.py", "src/rag_memories/main.py", "src/rag_memories/models.py", "src/rag_memories/repositories.py", "src/rag_memories/service.py", "tests/test_rag_memories.py", ".env.example", "infra/postgres/init/001_init.sql", "src/rag_memories/config.py"], decision="allow")
prefix_rule(pattern=["git", "push", "origin", "main"], decision="allow")
