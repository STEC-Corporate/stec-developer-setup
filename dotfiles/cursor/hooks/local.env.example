# Copiar para local.env (arquivo ignorado pelo git) na mesma pasta.
# export CURSOR_HOOK_TEST_CMD='npm run test'
# export CURSOR_HOOK_FAIL_ON_ERROR=0
# LLM Advisor — recomenda modelo ideal após cada resposta (detecta domínio da sessão)
export CURSOR_HOOK_STOP_CMD='bash ~/.cursor/hooks/llm-advisor.sh'

# Gate beforeSubmitPrompt (workflow-prompt-profissional quando pedido parece "plano novo"):
# Por padrão o gate está ligado no código. Para desligar permanentemente, descomente:
# export PLAN_BRIEF_GATE=0
# Um envio sem pausa mesmo com gate ligado: primeira linha do prompt = SKIP_PLAN_BRIEF
